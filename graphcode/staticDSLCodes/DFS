function dfs(Graph g, node start_node)
{
    propNode<bool> visited;
    g.attachNodeProperty(visited = False);

    start_node.visited = True;
    std::vector<node> stack;
    stack.push_back(start_node);

    while (stack.size() == 0)
    {
        node top = stack[stack.size() - 1];
        stack.pop_back();
        forall(nbr in g.nodes_from(top).filter(visited == False))
        {
            visited[nbr] = True;
            stack.push_back(nbr);
        }
    }
}